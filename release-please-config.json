{
  "include-v-in-tag": true,
  "include-component-in-tag": false,
  "packages": {
    ".": {
      "release-type": "go",
      "release-as": "1.0.0",
      "versioning": "always-bump-minor",
      "skip-changelog": true,
      "extra-files": [
        {
          "type": "json",
          "path": "package.template.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.version"
        },
        {
          "type": "json",
          "path": "package-lock.json",
          "jsonpath": "$.packages[''].version"
        }
      ]
    }
  }
}
